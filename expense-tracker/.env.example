# Expense Tracker - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Backend
# =============================================================================

# Node environment (development | production)
NODE_ENV=production

# Port the backend API listens on inside the container
PORT=3000

# Path to the JSONL data directory (inside the container)
DATA_PATH=/data

# =============================================================================
# Frontend (Vite build-time variables)
# =============================================================================

# Base URL for the backend API (used during Vite build)
# In production with nginx proxy, use /api
VITE_API_BASE=/api
